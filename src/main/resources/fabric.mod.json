{
	"schemaVersion": 1,
	"id": "true_health",
	"version": "${version}",
	"name": "True Health",
	"description": "Shows real (un-rounded) HP for you, your target, and the damage your attacks deal.",
	"authors": [
		"Dan Baggott"
	],
	"contact": {
		"sources": "https://github.com/dbaggott/mc-true-health"
	},
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"main": [
			"io.dnbg.minecraft.truehealth.TrueHealth"
		],
		"client": [
			"io.dnbg.minecraft.truehealth.client.TrueHealthClient"
		]
	},
	"mixins": [
		"true_health.mixins.json",
		{
			"config": "true_health.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
